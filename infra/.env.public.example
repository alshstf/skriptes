# ════════════════════════════════════════════════════════════════════════
#  .env для ПУБЛИЧНОГО (DMZ) деплоя skriptes — интернет-доступ без VPN.
#
#  Запуск (хардненинг-overlay + туннель Cloudflare):
#    docker compose -f docker-compose.release.yml \
#                   -f docker-compose.harden.yml \
#                   --env-file .env --profile public up -d
#
#  Это .env для ИЗОЛИРОВАННОГО DMZ-хоста (отдельная VM/VLAN, без доступа в LAN).
#  Отличия от обычного .env.example прокомментированы как  ⚠ DMZ.
#  Полный план развёртывания — вне репозитория (secure-publish-plan).
# ════════════════════════════════════════════════════════════════════════

# ── общее ───────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=skriptes
TZ=Europe/Moscow

# ── PostgreSQL ──────────────────────────────────────────────────
# ⚠ DMZ: НЕ дефолтные. Своя БД на DMZ-хосте, изолирована от homelab.
POSTGRES_USER=skriptes
POSTGRES_PASSWORD=__СГЕНЕРИРУЙ_СИЛЬНЫЙ__   # openssl rand -base64 24
POSTGRES_DB=skriptes

# ── Meilisearch ─────────────────────────────────────────────────
# ⚠ DMZ: в проде master-key ОБЯЗАТЕЛЕН (иначе индекс открыт по сети контейнеров).
MEILI_MASTER_KEY=__СГЕНЕРИРУЙ_СИЛЬНЫЙ__    # openssl rand -base64 32
MEILI_ENV=production

# ── Backend ─────────────────────────────────────────────────────
SKRIPTES_HTTP_ADDR=:8080
SKRIPTES_LOG_LEVEL=info
SKRIPTES_LOG_FORMAT=json
# ⚠ DMZ: пин конкретной версии (не latest) — воспроизводимость деплоя.
SKRIPTES_VERSION=1.5.1

# ── Внешнее обогащение (Google Books) ───────────────────────────
# Можно оставить пустым на DMZ (обогащение лучше гонять на homelab-инстансе,
# а в DMZ заливать уже готовую коллекцию). Если задаёте — отдельный ключ.
SKRIPTES_GOOGLE_BOOKS_API_KEY=

# ── Auth / cookies ──────────────────────────────────────────────
# ⚠ DMZ: TLS терминируется на edge Cloudflare → cookie только по HTTPS.
SKRIPTES_COOKIE_SECURE=true
# ⚠ DMZ: ваш публичный домен (тот, что заведён в Cloudflare).
SKRIPTES_COOKIE_DOMAIN=skriptes.example.com
# ⚠ DMZ: origin = публичный https-домен (CSRF: мутирующие запросы только оттуда).
SKRIPTES_ALLOWED_ORIGINS=https://skriptes.example.com
# Анти-брутфорс логина: лимит НЕУДАЧНЫХ попыток на окно (IP 5мин / email 15мин).
# ⚠ DMZ: ОСТАВИТЬ включённым (публичный фронт). 0 = выключить (только за своим WAF).
SKRIPTES_LOGIN_RATELIMIT_IP=10
SKRIPTES_LOGIN_RATELIMIT_EMAIL=20

# ── Volumes (read-only данные) ──────────────────────────────────
# ⚠ DMZ-КРИТИЧНО: это ЛОКАЛЬНЫЙ путь на DMZ-хосте, а НЕ NFS-mount с NAS!
# NFS-mount = ровно та дыра lateral-movement, которую мы закрываем: DMZ НИКОГДА
# не подключается в LAN. Вместо этого TrueNAS ОДНОСТОРОННЕ пушит копию библиотеки
# в этот локальный каталог (инициатор — NAS; DMZ исходящих в LAN не делает).
# Цена — дублирование ~300ГБ. См. фазу «односторонний пуш библиотеки» в плане.
BOOKS_HOST_PATH=/srv/skriptes/books
INPX_HOST_PATH=/srv/skriptes/inpx

# ── Send-to-Kindle / SMTP (опц.) ───────────────────────────────
# Если нужен Send-to-Kindle на публичном инстансе — задайте SMTP (app-password).
SKRIPTES_SMTP_HOST=
SKRIPTES_SMTP_PORT=587
SKRIPTES_SMTP_USER=
SKRIPTES_SMTP_PASSWORD=
SKRIPTES_SMTP_FROM=
SKRIPTES_SMTP_USE_TLS=false

# ── Caddy / hostname ────────────────────────────────────────────
# ⚠ DMZ: caddy слушает ВНУТРИ docker-сети; наружу его НЕ публикуем (нет ports на
# хосте при туннеле). cloudflared ходит в caddy:80 по внутренней сети. Порты
# 80/443 на DMZ-хосте можно НЕ открывать вообще (0 входящих — туннель исходящий).
SKRIPTES_HOST=skriptes.example.com
HTTP_PORT=80
HTTPS_PORT=443

# ── Cloudflare Tunnel (профиль public) ─────────────────────────
# Токен туннеля из Cloudflare Zero Trust → Networks → Tunnels → (создать) →
# «Install connector» → Docker → значение TUNNEL_TOKEN. Туннель = 0 входящих
# портов, origin-IP скрыт.
#
# В дашборде туннеля настраивается:
#   • Public hostname:  skriptes.example.com  →  Service: http://caddy:80
#   • Cloudflare Access (Zero Trust → Access → Applications):
#       – приложение на skriptes.example.com, политика: список email близких
#         (One-time PIN) — identity-гейт ДО приложения;
#       – ОТДЕЛЬНАЯ строгая политика на путь  /admin*  → только ваш email;
#       – ⚠ /opds НАРУЖУ НЕ ПУБЛИКУЕМ: либо не добавлять public hostname-путь
#         для /opds, либо Access-политика Deny на  /opds*  (Basic-Auth OPDS
#         несовместим с Access). См. граблю про OPDS.
CLOUDFLARE_TUNNEL_TOKEN=__ВСТАВЬ_ТОКЕН_ТУННЕЛЯ__
