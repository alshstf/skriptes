{
	# Локальный CA Caddy выдаст сертификат для *.localhost автоматически.
	# Для прод-домена замените на реальный + email.
	# email you@example.com
	auto_https disable_redirects
}

{$SKRIPTES_HOST} {
	encode zstd gzip

	# API → backend
	@api path /api/* /healthz /readyz
	handle @api {
		reverse_proxy backend:8080
	}

	# OPDS-каталог для e-reader клиентов (KOReader/Moon+Reader/…) → backend.
	# Своя HTTP Basic авторизация внутри backend; без этого матчера /opds/*
	# падал в SPA-фолбэк (frontend отдавал index.html вместо каталога).
	@opds path /opds/*
	handle @opds {
		reverse_proxy backend:8080
	}

	# Всё остальное → frontend (nginx со SPA-фолбэком)
	# :8080 — nginx-unprivileged слушает 8080 (non-root), не 80
	handle {
		reverse_proxy frontend:8080
	}
}
