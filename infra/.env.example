# ── общее ───────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=skriptes
TZ=Europe/Moscow

# ── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_USER=skriptes
POSTGRES_PASSWORD=skriptes
POSTGRES_DB=skriptes
POSTGRES_PORT=5432

# ── Meilisearch ─────────────────────────────────────────────────
# В dev можно оставить пустым; в проде задайте сильный ключ.
MEILI_MASTER_KEY=
MEILI_PORT=7700
MEILI_ENV=development

# ── Backend ─────────────────────────────────────────────────────
SKRIPTES_HTTP_ADDR=:8080
SKRIPTES_LOG_LEVEL=info
SKRIPTES_LOG_FORMAT=json
SKRIPTES_VERSION=dev
BACKEND_PORT=8080

# ── Volumes (read-only данные) ──────────────────────────────────
# Пути на ХОСТЕ к коллекции книг и inpx-файлам.
# В контейнере это всегда /data/books и /data/inpx.
BOOKS_HOST_PATH=./data/books
INPX_HOST_PATH=./data/inpx

# ── Caddy / hostname ────────────────────────────────────────────
SKRIPTES_HOST=skriptes.localhost
HTTP_PORT=80
HTTPS_PORT=443
