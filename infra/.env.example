# ── общее ───────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=skriptes
TZ=Europe/Moscow

# ── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_USER=skriptes
POSTGRES_PASSWORD=skriptes
POSTGRES_DB=skriptes
POSTGRES_PORT=5432

# ── Meilisearch ─────────────────────────────────────────────────
# В dev можно оставить пустым; в проде задайте сильный ключ.
MEILI_MASTER_KEY=
MEILI_PORT=7700
MEILI_ENV=development

# ── Backend ─────────────────────────────────────────────────────
SKRIPTES_HTTP_ADDR=:8080
SKRIPTES_LOG_LEVEL=info
SKRIPTES_LOG_FORMAT=json
SKRIPTES_VERSION=0.2.0-alpha.1
BACKEND_PORT=8080

# ── Auth / cookies ──────────────────────────────────────────────
# CookieSecure=true (продовый дефолт — за TLS).
# В чистом-HTTP dev на 127.0.0.1 без Caddy — поставьте false.
SKRIPTES_COOKIE_SECURE=true
# Пустая строка = текущий host.
SKRIPTES_COOKIE_DOMAIN=
# Список origin'ов через запятую, откуда разрешены мутирующие запросы (CSRF-защита).
SKRIPTES_ALLOWED_ORIGINS=https://skriptes.localhost

# ── Volumes (read-only данные) ──────────────────────────────────
# Пути на ХОСТЕ к коллекции книг и inpx-файлам.
# В контейнере это всегда /data/books и /data/inpx.
BOOKS_HOST_PATH=./data/books
INPX_HOST_PATH=./data/inpx

# ── Send-to-Kindle / SMTP ──────────────────────────────────────
# Если SMTP_HOST пуст — функция "Отправить на Kindle" недоступна
# (frontend показывает обычную кнопку Download, а API возвращает 503
# на /api/books/{id}/send-to-kindle).
#
# Примеры провайдеров:
#   Gmail:  HOST=smtp.gmail.com  PORT=587  USE_TLS=false  (STARTTLS)
#           USER = your-gmail-account@gmail.com
#           PASSWORD = app-password (НЕ основной пароль; создаётся в
#           https://myaccount.google.com/apppasswords)
#   Yandex: HOST=smtp.yandex.ru  PORT=465  USE_TLS=true   (implicit TLS)
#           USER/PASSWORD — пароль приложения Я.Почты.
#
# FROM-адрес обязан быть в списке "Утверждённые отправители" в
# https://www.amazon.com/hz/mycd/myx#/home/settings — иначе Amazon
# отбросит письмо. Если FROM пустой — берётся USER.
SKRIPTES_SMTP_HOST=
SKRIPTES_SMTP_PORT=587
SKRIPTES_SMTP_USER=
SKRIPTES_SMTP_PASSWORD=
SKRIPTES_SMTP_FROM=
SKRIPTES_SMTP_USE_TLS=false

# ── Caddy / hostname ────────────────────────────────────────────
SKRIPTES_HOST=skriptes.localhost
HTTP_PORT=80
HTTPS_PORT=443
