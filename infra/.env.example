# ── общее ───────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=skriptes
TZ=Europe/Moscow

# ── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_USER=skriptes
POSTGRES_PASSWORD=skriptes
POSTGRES_DB=skriptes
# POSTGRES_PORT — host-порт для прямого доступа из хоста (psql).
# Действует ТОЛЬКО в dev-compose (infra/docker-compose.yml). В release
# compose (docker-compose.release.yml) postgres не пробрасывается
# наружу — всё ходит через внутреннюю docker-сеть.
POSTGRES_PORT=5432

# ── Meilisearch ─────────────────────────────────────────────────
# В dev можно оставить пустым; в проде задайте сильный ключ.
MEILI_MASTER_KEY=
# MEILI_PORT — host-порт, действует только в dev-compose (см. выше про POSTGRES_PORT).
MEILI_PORT=7700
MEILI_ENV=development

# ── Backend ─────────────────────────────────────────────────────
SKRIPTES_HTTP_ADDR=:8080
SKRIPTES_LOG_LEVEL=info
SKRIPTES_LOG_FORMAT=json
SKRIPTES_VERSION=1.3.6
# BACKEND_PORT — host-порт, действует только в dev-compose. В release
# compose backend доступен только caddy через docker-сеть.
BACKEND_PORT=8080

# ── Внешнее обогащение (Google Books) ───────────────────────────
# Ключ Google Books API. ОБЯЗАТЕЛЕН для обогащения из Google Books
# (обложки / внешний рейтинг / группировка работ): без ключа GB отвечает
# 429 «quota exceeded» по общей анонимной квоте. Где взять: Google Cloud
# Console → APIs & Services → включить «Books API» → Credentials → API key.
# Квота считается на проект (free ≈ 1000 запросов/день, расширяемо).
# Пусто = GB-обогащение практически не работает (OpenLibrary ключа не требует).
SKRIPTES_GOOGLE_BOOKS_API_KEY=

# ── Auth / cookies ──────────────────────────────────────────────
# CookieSecure=true (продовый дефолт — за TLS).
# В чистом-HTTP dev на 127.0.0.1 без Caddy — поставьте false.
SKRIPTES_COOKIE_SECURE=true
# Пустая строка = текущий host.
SKRIPTES_COOKIE_DOMAIN=
# Список origin'ов через запятую, откуда разрешены мутирующие запросы (CSRF-защита).
SKRIPTES_ALLOWED_ORIGINS=https://skriptes.localhost

# ── Volumes (read-only данные) ──────────────────────────────────
# Пути на ХОСТЕ к коллекции книг и inpx-файлам.
# В контейнере это всегда /data/books и /data/inpx.
BOOKS_HOST_PATH=./data/books
INPX_HOST_PATH=./data/inpx

# ── Send-to-Kindle / SMTP ──────────────────────────────────────
# Если SMTP_HOST пуст — функция "Отправить на Kindle" недоступна
# (frontend показывает обычную кнопку Download, а API возвращает 503
# на /api/books/{id}/send-to-kindle).
#
# Примеры провайдеров:
#   Gmail:  HOST=smtp.gmail.com  PORT=587  USE_TLS=false  (STARTTLS)
#           USER = your-gmail-account@gmail.com
#           PASSWORD = app-password (НЕ основной пароль; создаётся в
#           https://myaccount.google.com/apppasswords)
#   Yandex: HOST=smtp.yandex.ru  PORT=465  USE_TLS=true   (implicit TLS)
#           USER/PASSWORD — пароль приложения Я.Почты.
#
# FROM-адрес обязан быть в списке "Утверждённые отправители" в
# https://www.amazon.com/hz/mycd/myx#/home/settings — иначе Amazon
# отбросит письмо. Если FROM пустой — берётся USER.
SKRIPTES_SMTP_HOST=
SKRIPTES_SMTP_PORT=587
SKRIPTES_SMTP_USER=
SKRIPTES_SMTP_PASSWORD=
SKRIPTES_SMTP_FROM=
SKRIPTES_SMTP_USE_TLS=false

# ── Caddy / hostname ────────────────────────────────────────────
# Hostname — Caddy получит TLS-сертификат через локальный CA для *.localhost
# либо через ACME (Let's Encrypt) для реального домена — отредактируйте
# Caddyfile если нужно.
SKRIPTES_HOST=skriptes.localhost
# HTTP_PORT / HTTPS_PORT — host-порты на которых слушает Caddy. Дефолт
# 80/443. В homelab'е, где эти порты уже заняты другим reverse-proxy,
# переопределите на свободные (например 8080/8443) — Caddy внутри
# контейнера остаётся на 80/443, наружу торчат указанные здесь.
#
# Полностью выключить Caddy (когда у вас уже есть свой edge proxy) —
# см. docker-compose.no-caddy.override.yml.
HTTP_PORT=80
HTTPS_PORT=443

# ── Override-only переменные (для docker-compose.no-caddy.override.yml) ──
# Если используете override без Caddy, здесь host-порты для backend и
# frontend (привязываются к 127.0.0.1, наружу пускает ваш edge proxy).
# BACKEND_HOST_PORT=8080
# FRONTEND_HOST_PORT=3000
